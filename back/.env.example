# Server
PORT=8080
APP_ENV=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Database mode: true = MariaDB, false = SQLite
USE_MARIADB=false

# MariaDB
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_DATABASE=

# SQLite
SQLITE_PATH=./data/app.db

# Auth
JWT_SECRET=replace-me-with-something-long-and-random
JWT_EXPIRY_HOURS=24

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Super-admins (only used by scripts/create_superusers.py)
SUPER_ADMIN_1_NAME=
SUPER_ADMIN_1_EMAIL=
SUPER_ADMIN_1_USERNAME=
SUPER_ADMIN_1_PASSWORD=

SUPER_ADMIN_2_NAME=
SUPER_ADMIN_2_EMAIL=
SUPER_ADMIN_2_USERNAME=
SUPER_ADMIN_2_PASSWORD=

